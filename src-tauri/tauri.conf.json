{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Seeker",
  "version": "0.1.0",
  "identifier": "dev.zhapar.seeker",
  "build": {
    "frontendDist": ["../index.html"],
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Seeker",
        "width": 1280,
        "height": 832,
        "minWidth": 920,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}

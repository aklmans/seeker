{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [],
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "web/platform/**/*.ts",
    "web/platform/**/*.js",
    "web/domain/**/*.ts",
    "web/domain/**/*.js"
  ],
  "exclude": ["node_modules", "src-tauri", "web/index.html"]
}
